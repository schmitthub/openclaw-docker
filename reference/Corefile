# CoreDNS allowlist — only whitelisted domains resolve.
# All other queries return NXDOMAIN.
# Forwards to Cloudflare malware-blocking DNS (1.1.1.2 / 1.0.0.2).
#
# This file mirrors the domain whitelist in envoy.yaml.
# DNS queries from uid 1000 (node) are redirected here by iptables in sidecar-entrypoint.sh.

# Infrastructure
clawhub.com {
    forward . 1.1.1.2 1.0.0.2
}
npmjs.org {
    forward . 1.1.1.2 1.0.0.2
}

# AI providers
anthropic.com {
    forward . 1.1.1.2 1.0.0.2
}
openai.com {
    forward . 1.1.1.2 1.0.0.2
}
googleapis.com {
    forward . 1.1.1.2 1.0.0.2
}
openrouter.ai {
    forward . 1.1.1.2 1.0.0.2
}
x.ai {
    forward . 1.1.1.2 1.0.0.2
}

# Homebrew / GitHub
github.com {
    forward . 1.1.1.2 1.0.0.2
}
githubusercontent.com {
    forward . 1.1.1.2 1.0.0.2
}
ghcr.io {
    forward . 1.1.1.2 1.0.0.2
}
brew.sh {
    forward . 1.1.1.2 1.0.0.2
}

# Go modules (used by Homebrew)
golang.org {
    forward . 1.1.1.2 1.0.0.2
}

# Discord
discordapp.com {
    forward . 1.1.1.2 1.0.0.2
}
discord.com {
    forward . 1.1.1.2 1.0.0.2
}
discord.gg {
    forward . 1.1.1.2 1.0.0.2
}
discord.media {
    forward . 1.1.1.2 1.0.0.2
}

# Tailscale (control plane, DERP relays, login, log)
tailscale.com {
    forward . 1.1.1.2 1.0.0.2
}

# Let's Encrypt (ACME for Tailscale Serve TLS certs)
letsencrypt.org {
    forward . 1.1.1.2 1.0.0.2
}

# Catch-all: NXDOMAIN for everything else
. {
    template ANY ANY {
        rcode NXDOMAIN
    }
    log
}
