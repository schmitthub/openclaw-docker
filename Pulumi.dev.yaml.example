# Example stack configuration for a dev server.
#
# Before running `pulumi up`, set required secrets:
#   pulumi config set --secret tailscaleAuthKey <your-tailscale-auth-key>
#
# Optional: set secret env vars for gateway setup commands and runtime:
#   pulumi config set --secret gatewaySecretEnv-dev '{"ANTHROPIC_API_KEY":"sk-ant-..."}'
#
# Gateway auth tokens are auto-generated and stored in Pulumi state.
# To override: pulumi config set --secret gatewayToken-<profile> <token>

config:
  openclaw-deploy:provider: hetzner
  openclaw-deploy:serverType: cx22
  openclaw-deploy:region: fsn1
  # openclaw-deploy:sshKeyId: "12345"  # Optional: auto-generates ED25519 SSH key if omitted
  openclaw-deploy:egressPolicy: []
  openclaw-deploy:gateways:
    - profile: dev
      version: latest
      port: 18789
      setupCommands:
        - >-
          onboard --non-interactive --tailscale serve --accept-risk
          --mode local --gateway-bind loopback
          --gateway-token "$OPENCLAW_GATEWAY_TOKEN"
          --no-install-daemon
          --auth-choice token --token-provider anthropic --token "$ANTHROPIC_API_KEY"
          # OpenRouter: --auth-choice openrouter-api-key --openrouter-api-key "$OPENROUTER_API_KEY"
          # OpenAI:     --auth-choice openai-api-key --openai-api-key "$OPENAI_API_KEY"
          --skip-channels --skip-skills --skip-daemon --skip-health
        - config set gateway.controlUi.dangerouslyAllowHostHeaderOriginFallback true
        - config set gateway.auth.mode trusted-proxy
        - config set gateway.trustedProxies '["127.0.0.1"]'
        - config set gateway.auth.trustedProxy.userHeader tailscale-user-login
        - config set gateway.controlUi.basePath /openclaw
  openclaw-deploy:gatewaySecretEnv-dev:
    secure: <encrypted>  # JSON: {"ANTHROPIC_API_KEY":"sk-ant-..."}
